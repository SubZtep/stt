#!/usr/bin/env bash
# stt-check — verify all configured models are available on the speaches server
set -uo pipefail

CONFIG_FILE="${STT_CONFIG:-$HOME/.config/stt.json}"
cfg() { [ -f "$CONFIG_FILE" ] && jq -r "$1 // empty" "$CONFIG_FILE" 2>/dev/null || true; }

url="$(cfg '.url')"; url="${url:-http://localhost:8000/v1}"
default_model="$(cfg '.model')"; default_model="${default_model:-Systran/faster-whisper-small}"
mapfile -t lang_models < <(jq -r '.models // {} | to_entries[] | "\(.key)=\(.value)"' "$CONFIG_FILE" 2>/dev/null || true)

pass=0; fail=0

check_model() {
  local label="$1" model="$2"
  local code
  code="$(curl -s -o /dev/null -w '%{http_code}' -X POST "$url/models/$model" 2>/dev/null)"
  if [ "$code" = "200" ]; then
    printf "  \e[32mOK\e[0m  [%s] %s\n" "$label" "$model"
    ((pass++)) || true
  else
    printf "  \e[31mFAIL\e[0m [%s] %s  (HTTP %s)\n" "$label" "$model" "$code"
    ((fail++)) || true
  fi
}

echo "Checking models against $url"
echo

check_model "default" "$default_model"

for entry in "${lang_models[@]}"; do
  lang="${entry%%=*}"; model="${entry#*=}"
  [ "$model" != "$default_model" ] && check_model "$lang" "$model"
done

echo
echo "Result: $pass ok, $fail failed"
[ "$fail" -eq 0 ]
