#!/usr/bin/env bash
# stt-check — verify all alias models are available on the speaches server
set -uo pipefail

CONFIG_FILE="${STT_CONFIG:-$HOME/.config/stt/config.json}"
ALIASES_FILE="${STT_ALIASES:-$HOME/.config/stt/aliases.json}"
cfg() { [ -f "$CONFIG_FILE" ] && jq -r "$1 // empty" "$CONFIG_FILE" 2>/dev/null || true; }

url="$(cfg '.url')"; url="${url:-http://localhost:8000/v1}"
mapfile -t alias_keys < <(jq -r 'keys[]' "$ALIASES_FILE" 2>/dev/null || true)

# fetch the list of already-downloaded models once
downloaded="$(curl -s "$url/models" 2>/dev/null | jq -r '.data[].id' 2>/dev/null || true)"

pass=0; fail=0

echo "Checking models against $url"
echo

for key in "${alias_keys[@]}"; do
  model="$(jq -r ".\"$key\".model // empty" "$ALIASES_FILE")"
  name="$(jq -r ".\"$key\".name // empty" "$ALIASES_FILE")"
  if echo "$downloaded" | grep -qxF "$model"; then
    printf "  \e[32mOK\e[0m  %-6s %-12s %s\n" "$key" "$name" "$model"
    ((pass++)) || true
  else
    printf "  \e[33m--\e[0m  %-6s %-12s %s\n" "$key" "$name" "$model"
    ((fail++)) || true
  fi
done

echo
echo "Result: $pass downloaded, $fail not yet fetched"
[ "$fail" -eq 0 ]
